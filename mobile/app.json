{
  "expo": {
    "name": "takda",
    "slug": "takda",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "plugins": [
      "expo-secure-store",
      [
        "react-native-health",
        {
          "healthSharePermission": "TAKDA needs access to your health data to track your steps and activity levels.",
          "healthUpdatePermission": "TAKDA needs permission to sync your activity data with your health profile."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.patrick.takda",
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSHealthShareUsageDescription": "TAKDA needs access to your health data to track your steps and activity levels.",
        "NSHealthUpdateUsageDescription": "TAKDA needs permission to sync your activity data with your health profile."
      }
    },
    "android": {
      "package": "com.patrick.takda",
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_HEART_RATE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "extra": {
      "eas": {
        "projectId": "b4cb072c-c2be-4953-bc18-597c62d1fc4c"
      }
    }
  }
}
